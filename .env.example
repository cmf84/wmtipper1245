# football-data.org API-Key (kostenlos registrieren: https://www.football-data.org/client/register)
FOOTBALL_DATA_API_KEY=dein_api_key_hier

# Competition-Code bei football-data.org (WM = WC)
FOOTBALL_DATA_COMPETITION=WC

# Passwort für den Admin-Login
ADMIN_PASSWORD=bitte-aendern

# Geheimnis zum Signieren der Session-Cookies (mind. 32 Zeichen)
SESSION_SECRET=bitte-ein-langes-zufaelliges-geheimnis-mit-min-32-zeichen

# Pfad zur SQLite-Datenbank (im Container auf das /data-Volume zeigen lassen)
DATABASE_PATH=./data/wmtipper.db

# Intervall des Hintergrund-Sync (Cron-Syntax). Standard: alle 2 Minuten
SYNC_CRON=*/10 * * * * *

# Sync-Poller beim Serverstart aktivieren (im Container: true)
ENABLE_SYNC=true

# Zeitzone für die Anzeige der Anstoßzeiten
TZ=Europe/Berlin
